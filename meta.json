{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "viam:conversation-bundle",
  "visibility": "public",
  "url": "https://github.com/viam-modules/conversation-bundle",
  "description": "Conversation related resources",
  "models": [
    {
      "api": "rdk:service:generic",
      "model": "viam:conversation-bundle:text-to-speech",
      "short_description": "Text-to-speech service using Google Cloud TTS API with audioout playback.",
      "markdown_link": "README.md#model-viamconversation-bundletext-to-speech"
    },
    {
      "api": "rdk:service:generic",
      "model": "viam:conversation-bundle:voice-command",
      "short_description": "Voice-command orchestrator: wake word + Google STT + Claude + TTS, classifies utterances against a configured list of commands and dispatches via DoCommand to target resources.",
      "markdown_link": "README.md#model-viamconversation-bundlevoice-command"
    }
  ],
  "applications": null,
  "markdown_link": "README.md",
  "entrypoint": "bin/conversation-bundle",
  "first_run": "first_run.sh",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64",
      "windows/amd64"
    ]
  }
}